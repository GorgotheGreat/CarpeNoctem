let stUnlocked=false;
function toggleSTView(){
  const panel=document.getElementById('st-panel');
  panel.classList.toggle('show');
  if(panel.classList.contains('show')&&!stUnlocked){
    document.getElementById('st-lock-screen').style.display='flex';
    document.getElementById('st-content').style.display='none';
  }
}
function checkSTPass(){
  const inp=document.getElementById('st-pass-input').value;
  dbGet('config',cfg=>{
    const pass=(cfg&&cfg.pass)||'storyteller';
    if(inp===pass){
      stUnlocked=true;
      document.getElementById('st-lock-screen').style.display='none';
      document.getElementById('st-content').style.display='block';
      const nameEl=document.getElementById('st-biz-name');if(nameEl&&cfg)nameEl.value=cfg.name||'Velvet Anchor';
      renderSTInventory();
    } else {
      document.getElementById('st-pass-error').style.display='block';
    }
  });
}

