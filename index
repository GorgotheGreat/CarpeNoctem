//  SCHEDULE
// ════════════════════════════════════════════════════════════
const DAYS=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
function renderSchedule(){
  const el=document.getElementById('sched-grid');if(!el)return;
  if(!_staff.length){el.innerHTML='<div style="padding:24px;text-align:center;color:var(--text3);font-size:13px">Add staff first</div>';return;}
  let html='<div class="schedule-grid">';
  html+='<div class="sched-cell header"></div>';
  DAYS.forEach(d=>html+=`<div class="sched-cell header">${d}</div>`);
  _staff.forEach(s=>{
    html+=`<div class="sched-cell name-col" style="font-size:11px">${s.name}</div>`;
    DAYS.forEach(day=>{
      const key=(s.name+'_'+day).replace(/[^a-z0-9_]/gi,'_');
      const shift=_schedule[key]||'';
      const chips={open:`<span class="shift-chip" style="background:rgba(52,199,89,0.15);color:var(--green)">O</span>`,
        close:`<span class="shift-chip" style="background:rgba(255,69,58,0.15);color:var(--red)">C</span>`,
        mid:`<span class="shift-chip" style="background:rgba(10,132,255,0.15);color:var(--blue)">M</span>`,
        off:`<span class="shift-chip" style="color:var(--text3)">—</span>`};
      html+=`<div class="sched-cell">${chips[shift]||''}</div>`;
    });
  });
  html+='</div>';el.innerHTML=html;
}
function openEditSchedule(){
  if(!_staff.length){showToast('Add staff first');return;}
  let rows='';
  _staff.forEach(s=>{
    rows+=`<tr><td style="font-size:12px;color:var(--text2);padding:4px 6px;white-space:nowrap">${s.name}</td>`;
    DAYS.forEach(day=>{
      const key=(s.name+'_'+day).replace(/[^a-z0-9_]/gi,'_');
      rows+=`<td style="padding:2px"><select class="input" id="s_${key}" style="font-size:10px;padding:2px 4px;width:56px">
        <option value="">—</option>
        <option value="open"${_schedule[key]==='open'?' selected':''}>Open</option>
        <option value="mid"${_schedule[key]==='mid'?' selected':''}>Mid</option>
        <option value="close"${_schedule[key]==='close'?' selected':''}>Close</option>
        <option value="off"${_schedule[key]==='off'?' selected':''}>Off</option>
      </select></td>`;
    });rows+='</tr>';
  });
  showModal(`
    <h2>Edit Weekly Schedule</h2>
    <div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse">
      <thead><tr><th></th>${DAYS.map(d=>`<th style="font-size:10px;color:var(--text3);padding:4px 2px">${d}</th>`).join('')}</tr></thead>
      <tbody>${rows}</tbody>
    </table></div>
    <div style="font-size:11px;color:var(--text3);margin-top:8px">O = Open · M = Mid · C = Close</div>
    <div class="modal-actions"><button class="btn" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="saveSchedule()">Save</button></div>
  `);
}
function saveSchedule(){
  const sched={};
  _staff.forEach(s=>{
    DAYS.forEach(day=>{
      const key=(s.name+'_'+day).replace(/[^a-z0-9_]/gi,'_');
      const el=document.getElementById('s_'+key);
      if(el&&el.value)sched[key]=el.value;
    });
  });
  dbSet('schedule',sched);closeModal();showToast('Schedule saved');
}

