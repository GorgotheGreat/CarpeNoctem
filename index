function stSendEmail(){
  const from=gv('st-email-from').trim(),sub=gv('st-email-subject').trim(),body=gv('st-email-body').trim(),priority=gv('st-email-priority');
  if(!from||!sub){showToast('Fill in From and Subject');return;}
  dbPush('emails',{from,subject:sub,body,priority,time:new Date().toLocaleString(),read:false,_ts:Date.now()});
  ['st-email-from','st-email-subject','st-email-body'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
  showToast('Email delivered to player inbox');
}

function stSendChat(){
  const from=gv('st-chat-from').trim(),text=gv('st-chat-msg').trim(),type=gv('st-chat-type');
  if(!from||!text){showToast('Fill in contact and message');return;}
  dbPush('chat_msgs',{contact:from,sender:type==='system'?'system':'npc',text,time:nowTime(),type,_ts:Date.now()});
  document.getElementById('st-chat-msg').value='';
  showToast('Message sent');
}

function stAddTransaction(){
  const label=gv('st-tx-label').trim(),amount=parseFloat(gv('st-tx-amount')),type=gv('st-tx-type'),date=gv('st-tx-date').trim();
  if(!label||!amount){showToast('Fill in label and amount');return;}
  dbPush('transactions',{label,type,amount,date,_ts:Date.now()});
  ['st-tx-label','st-tx-amount','st-tx-date'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
  showToast('Transaction posted to player bank');
}

function stFileIncident(){
  dbPush('incidents',{title:gv('st-inc-title'),date:gv('st-inc-date'),severity:gv('st-inc-sev'),body:gv('st-inc-body'),filed:'ST',_ts:Date.now()});
  ['st-inc-title','st-inc-date','st-inc-body'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
  showToast('Incident filed');
}

function stPostReport(){
  dbPush('reports',{date:gv('st-rep-date'),headline:gv('st-rep-headline'),body:gv('st-rep-body'),posted:new Date().toLocaleString(),_ts:Date.now()});
  ['st-rep-date','st-rep-headline','st-rep-body'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
  showToast('Report posted');
}

function stSaveConfig(){
  const name=gv('st-biz-name')||'Velvet Anchor';
  const pass=gv('st-new-pass');
  dbGet('config',cfg=>{
    cfg=cfg||{pass:'storyteller'};
    cfg.name=name;
    if(pass)cfg.pass=pass;
    dbSet('config',cfg);
    document.getElementById('mb-logo').textContent='⬡ '+name;
    document.title=name+' — Manager Console';
    showToast('Config saved');
  });
}

function confirmClearAll(){
  if(confirm('Reset ALL data? This cannot be undone and affects BOTH player and ST.')){
    ['emails','transactions','staff','todos','chat_msgs','inventory','incidents','schedule','contacts','reports'].forEach(k=>dbSet(k,null));
    showToast('All data cleared');
  }
}

