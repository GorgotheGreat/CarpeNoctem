function renderMailList(){
  const el=document.getElementById('mail-list');if(!el)return;
  const unread=_emails.filter(e=>!e.read).length;
  const ct=document.getElementById('mail-count');
  if(ct)ct.textContent=unread?`${unread} unread`:`${_emails.length} messages`;
  el.innerHTML=_emails.length?'':'<div style="padding:24px;text-align:center;color:var(--text3);font-size:13px">No messages</div>';
  _emails.forEach((m,i)=>{
    const d=document.createElement('div');
    d.className='email-list-item'+(m.read?'':' unread');
    const pTag=m.priority==='urgent'?`<span class="pill pill-red" style="font-size:10px">Urgent</span>`:m.priority==='info'?`<span class="pill pill-blue" style="font-size:10px">Info</span>`:'';
    d.innerHTML=`
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
        <div style="flex:1;min-width:0">
          <div style="display:flex;align-items:center;gap:6px">
            ${!m.read?'<div class="email-unread-dot"></div>':'<div style="width:7px"></div>'}
            <div style="font-size:12px;color:var(--text2);font-weight:500">${m.from}</div>${pTag}
          </div>
          <div class="email-list-item" style="font-size:13px;margin-left:13px;margin-top:2px;padding:0;border:none;${m.read?'color:var(--text2)':'color:var(--text);font-weight:600'}">${m.subject}</div>
          <div style="font-size:11px;color:var(--text3);margin-left:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${(m.body||'').slice(0,80)}</div>
        </div>
        <div style="font-size:10px;color:var(--text3);white-space:nowrap">${m.time||''}</div>
      </div>
    `;
    d.onclick=()=>openEmail(i,m._key);
    el.appendChild(d);
  });
}

function openEmail(idx,key){
  const m=_emails[idx];if(!m)return;
  currentEmailId={idx,key:key||m._key};
  // Mark read
  if(key)dbSet('emails/'+key+'/read',true);
  document.getElementById('mail-list-pane').style.display='none';
  document.getElementById('mail-view').classList.add('active');
  document.getElementById('mail-view-from').textContent='From: '+m.from;
  document.getElementById('mail-view-subject').textContent=m.subject;
  document.getElementById('mail-view-time').textContent=m.time||'';
  let body=m.body||'';
  if(m.replies){const rArr=Array.isArray(m.replies)?m.replies:Object.values(m.replies);rArr.forEach(r=>{body+='\n\n—— Your Reply ——\n'+r;});}
  document.getElementById('mail-view-body').textContent=body;
}

function backToMailList(){
  document.getElementById('mail-list-pane').style.display='';
  document.getElementById('mail-view').classList.remove('active');
  currentEmailId=null;
}

function sendReply(){
  if(!currentEmailId)return;
  const inp=document.getElementById('mail-reply-input');
  const val=inp.value.trim();if(!val)return;
  dbPush('emails/'+currentEmailId.key+'/replies',val);
  inp.value='';showToast('Reply saved');
}

function updateMailBadge(){
  const unread=_emails.filter(e=>!e.read).length;
  const b=document.getElementById('mail-badge');
  if(b){b.textContent=unread||'';b.style.display=unread?'flex':'none';}
}

