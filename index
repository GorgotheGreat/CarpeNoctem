<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Velvet Anchor — Manager Console</title>
<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">

<!-- Firebase v9 compat (CDN) -->
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-database-compat.js"></script>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --border:rgba(255,255,255,0.10);
  --border2:rgba(255,255,255,0.06);
  --text:#e8e8ed;
  --text2:#98989f;
  --text3:#636366;
  --accent:#bf9aff;
  --accent2:#9f6fff;
  --green:#34c759;
  --red:#ff453a;
  --amber:#ffd60a;
  --blue:#0a84ff;
  --radius:14px;
  --radius-sm:8px;
  --radius-xs:5px;
  --font:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;
  --mono:'Geist Mono','SF Mono','Menlo',monospace;
  --blur:saturate(180%) blur(20px);
}
body{font-family:var(--font);background:linear-gradient(135deg,#1a0533 0%,#0d1a2e 40%,#0a0f1a 100%);min-height:100vh;color:var(--text);overflow:hidden;position:relative;}
body::before{content:'';position:fixed;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.012'%3E%3Ccircle cx='30' cy='30' r='1'/%3E%3C/g%3E%3C/svg%3E");pointer-events:none;z-index:0;}

/* ── FIREBASE CONFIG SCREEN ── */
#config-screen{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.92);backdrop-filter:blur(8px);}
.config-box{background:#111113;border:0.5px solid var(--border);border-radius:var(--radius);padding:32px;width:500px;max-width:95vw;}
.config-box h1{font-size:20px;font-weight:600;color:var(--accent);margin-bottom:6px;}
.config-box p{font-size:13px;color:var(--text2);margin-bottom:20px;line-height:1.6;}
.config-step{background:rgba(255,255,255,0.04);border-radius:var(--radius-sm);padding:14px;margin-bottom:12px;border-left:3px solid var(--accent2);}
.config-step h3{font-size:12px;font-weight:600;color:var(--accent);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px;}
.config-step p{font-size:12px;color:var(--text2);margin-bottom:8px;}
.config-step code{font-family:var(--mono);font-size:11px;color:var(--amber);background:rgba(255,214,10,0.08);padding:2px 6px;border-radius:4px;}
.cfg-input-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px;}
.status-dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:6px;}
.status-dot.green{background:var(--green);box-shadow:0 0 6px var(--green);}
.status-dot.red{background:var(--red);}
.status-dot.amber{background:var(--amber);animation:pulse 1s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

/* ── MENUBAR ── */
#menubar{position:fixed;top:0;left:0;right:0;height:28px;background:rgba(13,13,15,0.75);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);border-bottom:0.5px solid var(--border2);display:flex;align-items:center;padding:0 16px;justify-content:space-between;z-index:1000;font-size:13px;}
.mb-left{display:flex;align-items:center;gap:20px;}
.mb-logo{font-size:14px;font-weight:600;color:var(--accent);}
.mb-item{color:var(--text2);cursor:pointer;transition:color .15s;}
.mb-item:hover{color:var(--text);}
.mb-right{display:flex;align-items:center;gap:12px;color:var(--text2);font-size:12px;}
.mb-time{font-family:var(--mono);font-size:11px;color:var(--text);}
.sync-indicator{display:flex;align-items:center;gap:5px;font-size:11px;}

/* ── DESKTOP ── */
#desktop{position:fixed;inset:28px 0 72px 0;overflow:hidden;z-index:1;}

/* ── WINDOWS ── */
.win{position:absolute;background:rgba(28,28,30,0.88);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);border:0.5px solid var(--border);border-radius:var(--radius);box-shadow:0 20px 60px rgba(0,0,0,0.6),0 0 0 0.5px rgba(255,255,255,0.05);display:flex;flex-direction:column;min-width:280px;min-height:200px;overflow:hidden;transition:box-shadow .2s;}
.win.active{box-shadow:0 24px 80px rgba(0,0,0,0.75),0 0 0 0.5px rgba(255,255,255,0.08);}
.win-titlebar{height:40px;display:flex;align-items:center;padding:0 14px;gap:10px;background:rgba(40,40,44,0.6);border-bottom:0.5px solid var(--border2);cursor:move;flex-shrink:0;}
.win-dots{display:flex;gap:6px;align-items:center;margin-right:4px;}
.win-dot{width:11px;height:11px;border-radius:50%;cursor:pointer;transition:filter .15s;}
.win-dot.close{background:#ff5f57;}
.win-dot.min{background:#febc2e;}
.win-dot.max{background:#28c840;}
.win-title{font-size:13px;font-weight:500;color:var(--text);flex:1;text-align:center;}
.win-body{flex:1;overflow-y:auto;padding:0;}
.win-body::-webkit-scrollbar{width:4px;}
.win-body::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
.win-resize{position:absolute;bottom:0;right:0;width:14px;height:14px;cursor:se-resize;opacity:0;}

/* ── DOCK ── */
#dock{position:fixed;bottom:10px;left:50%;transform:translateX(-50%);background:rgba(28,28,30,0.72);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);border:0.5px solid var(--border);border-radius:20px;padding:8px 16px;display:flex;align-items:center;gap:6px;box-shadow:0 8px 32px rgba(0,0,0,0.5);z-index:1000;}
.dock-item{display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;padding:4px 8px;border-radius:10px;transition:background .15s,transform .1s;position:relative;}
.dock-item:hover{background:rgba(255,255,255,0.07);transform:translateY(-3px);}
.dock-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;}
.dock-label{font-size:9px;color:var(--text3);white-space:nowrap;}
.dock-dot{position:absolute;bottom:2px;left:50%;transform:translateX(-50%);width:4px;height:4px;border-radius:50%;background:var(--text2);display:none;}
.dock-item.open .dock-dot{display:block;}
.dock-badge{position:absolute;top:0;right:4px;background:var(--red);color:#fff;font-size:8px;font-weight:600;min-width:14px;height:14px;border-radius:7px;display:none;align-items:center;justify-content:center;padding:0 3px;}

/* ── COMMON ── */
.pill{display:inline-flex;align-items:center;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:500;}
.pill-green{background:rgba(52,199,89,0.15);color:var(--green);}
.pill-red{background:rgba(255,69,58,0.15);color:var(--red);}
.pill-amber{background:rgba(255,214,10,0.15);color:var(--amber);}
.pill-blue{background:rgba(10,132,255,0.15);color:var(--blue);}
.pill-purple{background:rgba(191,154,255,0.15);color:var(--accent);}
.pill-gray{background:rgba(152,152,159,0.15);color:var(--text2);}
.row-item{display:flex;align-items:center;gap:10px;padding:10px 16px;border-bottom:0.5px solid var(--border2);transition:background .12s;cursor:pointer;}
.row-item:hover{background:rgba(255,255,255,0.03);}
.avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;flex-shrink:0;}
.btn{display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:var(--radius-xs);font-size:12px;font-weight:500;cursor:pointer;border:0.5px solid var(--border);background:rgba(255,255,255,0.06);color:var(--text);transition:background .12s;font-family:var(--font);}
.btn:hover{background:rgba(255,255,255,0.10);}
.btn-primary{background:var(--accent2);border-color:var(--accent);color:#fff;}
.btn-primary:hover{background:var(--accent);}
.btn-danger{background:rgba(255,69,58,0.15);border-color:var(--red);color:var(--red);}
.input{background:rgba(255,255,255,0.07);border:0.5px solid var(--border);border-radius:var(--radius-xs);color:var(--text);font-family:var(--font);font-size:13px;padding:7px 11px;outline:none;width:100%;transition:border-color .15s;}
.input:focus{border-color:var(--accent2);background:rgba(255,255,255,0.09);}
.input::placeholder{color:var(--text3);}
textarea.input{resize:vertical;min-height:70px;}
label{font-size:12px;color:var(--text2);display:block;margin-bottom:4px;}
select.input option{background:#1c1c1e;color:var(--text);}

/* ── MODAL ── */
#modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);z-index:2000;align-items:center;justify-content:center;}
#modal-overlay.show{display:flex;}
.modal{background:#1c1c1e;border:0.5px solid var(--border);border-radius:var(--radius);box-shadow:0 30px 80px rgba(0,0,0,0.8);padding:24px;width:440px;max-width:95vw;max-height:85vh;overflow-y:auto;}
.modal h2{font-size:17px;font-weight:600;margin-bottom:16px;}
.form-row{margin-bottom:13px;}
.modal-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:20px;}

/* ── APP STYLES ── */
.email-list-item{padding:12px 16px;border-bottom:0.5px solid var(--border2);cursor:pointer;transition:background .12s;}
.email-list-item:hover{background:rgba(255,255,255,0.03);}
.email-list-item.unread .email-subject{font-weight:600;color:var(--text);}
.email-unread-dot{width:7px;height:7px;border-radius:50%;background:var(--accent2);flex-shrink:0;}
.email-view{padding:16px;display:none;flex-direction:column;height:100%;}
.email-view.active{display:flex;}

.balance-hero{padding:20px 16px;text-align:center;background:linear-gradient(135deg,rgba(159,111,255,0.08),rgba(10,132,255,0.05));}
.balance-amount{font-size:36px;font-weight:300;font-family:var(--mono);margin:4px 0;}
.tx-item{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;border-bottom:0.5px solid var(--border2);}
.tx-amount{font-size:14px;font-weight:500;font-family:var(--mono);}
.tx-amount.pos{color:var(--green);}
.tx-amount.neg{color:var(--red);}

.staff-card{padding:12px 16px;border-bottom:0.5px solid var(--border2);display:flex;gap:12px;align-items:flex-start;cursor:pointer;transition:background .12s;}
.staff-card:hover{background:rgba(255,255,255,0.03);}
.stars{color:var(--amber);font-size:11px;}

.chat-contact-list{width:155px;border-right:0.5px solid var(--border2);flex-shrink:0;overflow-y:auto;}
.chat-contact{padding:10px 12px;border-bottom:0.5px solid var(--border2);cursor:pointer;transition:background .12s;}
.chat-contact:hover,.chat-contact.active{background:rgba(255,255,255,0.05);}
.chat-bubble{max-width:78%;padding:8px 12px;border-radius:14px;font-size:12px;line-height:1.5;}
.chat-bubble.npc{background:rgba(255,255,255,0.09);border-bottom-left-radius:4px;}
.chat-bubble.player{background:var(--accent2);color:#fff;align-self:flex-end;border-bottom-right-radius:4px;}
.chat-bubble.system{background:rgba(255,214,10,0.1);color:var(--amber);font-style:italic;font-size:11px;align-self:center;border-radius:8px;padding:4px 10px;}

.todo-item{display:flex;align-items:center;gap:10px;padding:9px 16px;border-bottom:0.5px solid var(--border2);}
.todo-cb{width:16px;height:16px;border-radius:50%;border:1.5px solid var(--border);cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:background .12s,border-color .12s;}
.todo-cb.checked{background:var(--accent2);border-color:var(--accent2);}
.todo-del{opacity:0;font-size:14px;color:var(--text3);cursor:pointer;transition:opacity .12s;}
.todo-item:hover .todo-del{opacity:1;}

.inv-item{display:flex;align-items:center;padding:10px 16px;border-bottom:0.5px solid var(--border2);gap:10px;}
.inv-bar-track{flex:1;height:5px;background:rgba(255,255,255,0.08);border-radius:3px;overflow:hidden;}
.inv-bar-fill{height:100%;border-radius:3px;transition:width .4s;}

.incident-item{padding:12px 16px;border-bottom:0.5px solid var(--border2);}
.schedule-grid{display:grid;grid-template-columns:80px repeat(7,1fr);font-size:11px;}
.sched-cell{padding:4px 2px;border-right:0.5px solid var(--border2);border-bottom:0.5px solid var(--border2);min-height:28px;text-align:center;}
.sched-cell.header{font-weight:500;color:var(--text2);background:rgba(255,255,255,0.03);font-size:10px;padding:6px 2px;}
.sched-cell.name-col{text-align:left;padding-left:6px;color:var(--text2);}
.shift-chip{display:inline-block;padding:1px 4px;border-radius:3px;font-size:9px;font-weight:500;margin:1px;}

.report-item{padding:12px 16px;border-bottom:0.5px solid var(--border2);cursor:pointer;transition:background .12s;}
.report-item:hover{background:rgba(255,255,255,0.03);}
.report-body{font-size:12px;color:var(--text2);line-height:1.6;margin-top:6px;display:none;white-space:pre-wrap;}
.report-body.show{display:block;}

.rolodex-item{display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:0.5px solid var(--border2);cursor:pointer;transition:background .12s;}
.rolodex-item:hover{background:rgba(255,255,255,0.03);}

/* ── ST PANEL ── */
#st-panel{display:none;position:fixed;inset:0;z-index:3000;background:#000;overflow-y:auto;}
#st-panel.show{display:block;}
.st-header{background:#0a0a0c;border-bottom:0.5px solid var(--border);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10;}
.st-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;padding:20px 24px;max-width:1100px;margin:0 auto;}
.st-card{background:#0d0d0f;border:0.5px solid var(--border);border-radius:var(--radius);padding:18px;}
.st-card h2{font-size:13px;font-weight:600;color:var(--text2);margin-bottom:14px;text-transform:uppercase;letter-spacing:.5px;}
.st-full{grid-column:1/-1;}
.gen-result{margin-top:14px;padding:14px;background:rgba(255,255,255,0.04);border-radius:var(--radius-sm);display:none;}
.gen-result.show{display:block;}

.wallpaper-option{width:60px;height:40px;border-radius:6px;cursor:pointer;border:2px solid transparent;transition:border-color .15s,transform .1s;flex-shrink:0;}
.wallpaper-option.active{border-color:var(--accent);}
.wallpaper-option:hover{transform:scale(1.05);}

#toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%) translateY(20px);background:#1c1c1e;border:0.5px solid var(--border);border-radius:10px;padding:10px 18px;font-size:13px;box-shadow:0 8px 32px rgba(0,0,0,0.5);z-index:9000;opacity:0;transition:opacity .2s,transform .2s;pointer-events:none;}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* live pulse on new messages */
@keyframes newmsg{0%{background:rgba(159,111,255,0.15)}100%{background:transparent}}
.new-msg-flash{animation:newmsg 1.2s ease-out;}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════
     FIREBASE CONFIG SCREEN
════════════════════════════════════════════════════════ -->
<div id="config-screen">
  <div class="config-box">
    <h1>⬡ Velvet Anchor Setup</h1>
    <p>Connect to Firebase for real-time sync between you (ST) and your player. This takes about 2 minutes and is free forever on Firebase's Spark plan.</p>

    <div class="config-step">
      <h3>Step 1 — Create Firebase Project</h3>
      <p>Go to <strong>console.firebase.google.com</strong> → <em>Add project</em> → name it (e.g. "velvet-anchor") → disable Google Analytics → Create.</p>
    </div>

    <div class="config-step">
      <h3>Step 2 — Enable Realtime Database</h3>
      <p>In your project: <em>Build → Realtime Database → Create database</em> → choose any region → start in <strong>test mode</strong> → Enable.</p>
    </div>

    <div class="config-step">
      <h3>Step 3 — Get your config</h3>
      <p>Go to <em>Project Settings (⚙️) → Your apps → Add app → Web (&lt;/&gt;)</em> → register app → copy the <code>firebaseConfig</code> object values below.</p>
    </div>

    <div style="margin-bottom:14px">
      <div class="cfg-input-grid">
        <div class="form-row" style="margin:0"><label>API Key</label><input class="input" id="cfg-apiKey" placeholder="AIzaSy…"></div>
        <div class="form-row" style="margin:0"><label>Auth Domain</label><input class="input" id="cfg-authDomain" placeholder="project.firebaseapp.com"></div>
        <div class="form-row" style="margin:0"><label>Database URL</label><input class="input" id="cfg-dbURL" placeholder="https://project-default-rtdb.firebaseio.com"></div>
        <div class="form-row" style="margin:0"><label>Project ID</label><input class="input" id="cfg-projectId" placeholder="project-id"></div>
        <div class="form-row" style="margin:0"><label>Storage Bucket</label><input class="input" id="cfg-storageBucket" placeholder="project.appspot.com"></div>
        <div class="form-row" style="margin:0"><label>Messaging Sender ID</label><input class="input" id="cfg-messagingSenderId" placeholder="123456789"></div>
        <div class="form-row" style="margin:0" style="grid-column:1/-1"><label>App ID</label><input class="input" id="cfg-appId" placeholder="1:123:web:abc…"></div>
      </div>
      <div style="margin-top:6px;font-size:11px;color:var(--text3)">Your config is saved locally in this browser only. The Firebase DB URL is the only required field if you paste the full config below.</div>
    </div>

    <div class="form-row">
      <label>Or paste the entire firebaseConfig JSON object</label>
      <textarea class="input" id="cfg-paste" placeholder='{"apiKey":"...","authDomain":"...","databaseURL":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}' style="min-height:60px;font-size:11px;font-family:var(--mono)"></textarea>
    </div>

    <div style="display:flex;gap:10px;align-items:center;margin-top:4px">
      <button class="btn btn-primary" onclick="connectFirebase()">Connect & Launch</button>
      <span id="cfg-status" style="font-size:12px;color:var(--text2)"></span>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     MAIN APP (hidden until Firebase connected)
════════════════════════════════════════════════════════ -->
<div id="app" style="display:none">

<!-- Menubar -->
<div id="menubar">
  <div class="mb-left">
    <span class="mb-logo" id="mb-logo">⬡ Velvet Anchor</span>
    <span class="mb-item" onclick="openWallpaperPicker()">Appearance</span>
    <span class="mb-item" onclick="toggleSTView()">ST View</span>
  </div>
  <div class="mb-right">
    <div class="sync-indicator" id="sync-indicator">
      <span class="status-dot amber" id="sync-dot"></span>
      <span id="sync-label">Connecting…</span>
    </div>
    <span id="mb-time" class="mb-time"></span>
  </div>
</div>

<!-- Desktop -->
<div id="desktop"></div>

<!-- Dock -->
<div id="dock">
  <div class="dock-item" id="dock-mail" onclick="openApp('mail')">
    <div class="dock-icon" style="background:linear-gradient(145deg,#1a6fff,#0050e0)">✉️</div>
    <span class="dock-label">Mail</span><div class="dock-dot"></div>
    <div class="dock-badge" id="mail-badge"></div>
  </div>
  <div class="dock-item" id="dock-bank" onclick="openApp('bank')">
    <div class="dock-icon" style="background:linear-gradient(145deg,#2a7a1a,#1a5c10)">💵</div>
    <span class="dock-label">Bank</span><div class="dock-dot"></div>
  </div>
  <div class="dock-item" id="dock-staff" onclick="openApp('staff')">
    <div class="dock-icon" style="background:linear-gradient(145deg,#5a2d9a,#3a1a6a)">👥</div>
    <span class="dock-label">Staff</span><div class="dock-dot"></div>
  </div>
  <div class="dock-item" id="dock-todo" onclick="openApp('todo')">
    <div class="dock-icon" style="background:linear-gradient(145deg,#c85000,#8a3200)">✅</div>
    <span class="dock-label">Tasks</span><div class="dock-dot"></div>
  </div>
  <div class="dock-item" id="dock-chat" onclick="openApp('chat')">
    <div class="dock-icon" style="background:linear-gradient(145deg,#00a878,#007852)">💬</div>
    <span class="dock-label">Comms</span><div class="dock-dot"></div>
    <div class="dock-badge" id="chat-badge"></div>
  </div>
  <div class="dock-item" id="dock-inventory" onclick="openApp('inventory')">
    <div class="dock-icon" style="background:linear-gradient(145deg,#8a6a00,#5c4700)">🍾</div>
    <span class="dock-label">Inventory</span><div class="dock-dot"></div>
  </div>
  <div class="dock-item" id="dock-incident" onclick="openApp('incident')">
    <div class="dock-icon" style="background:linear-gradient(145deg,#c82a2a,#8a1a1a)">⚠️</div>
    <span class="dock-label">Incidents</span><div class="dock-dot"></div>
  </div>
  <div class="dock-item" id="dock-schedule" onclick="openApp('schedule')">
    <div class="dock-icon" style="background:linear-gradient(145deg,#1a8aaa,#106080)">📅</div>
    <span class="dock-label">Schedule</span><div class="dock-dot"></div>
  </div>
  <div class="dock-item" id="dock-rolodex" onclick="openApp('rolodex')">
