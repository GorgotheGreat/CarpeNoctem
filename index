// ════════════════════════════════════════════════════════════
//  FIREBASE INIT
// ════════════════════════════════════════════════════════════
let db=null;
const LISTENERS={};

function connectFirebase(){
  let cfg={};
  const paste=document.getElementById('cfg-paste').value.trim();
  if(paste){
    try{cfg=JSON.parse(paste);}catch(e){setStatus('❌ Invalid JSON — check your paste','var(--red)');return;}
  } else {
    cfg={
      apiKey:g('cfg-apiKey'),authDomain:g('cfg-authDomain'),databaseURL:g('cfg-dbURL'),
      projectId:g('cfg-projectId'),storageBucket:g('cfg-storageBucket'),
      messagingSenderId:g('cfg-messagingSenderId'),appId:g('cfg-appId')
    };
  }
  if(!cfg.databaseURL){setStatus('❌ Database URL is required','var(--red)');return;}
  setStatus('Connecting…','var(--amber)');
  try{
    if(firebase.apps.length)firebase.app().delete();
    firebase.initializeApp(cfg);
    db=firebase.database();
    // Test connection
    db.ref('.info/connected').on('value',snap=>{
      const connected=snap.val();
      setSyncStatus(connected);
      if(connected){
        localStorage.setItem('va_firebase_cfg',JSON.stringify(cfg));
        document.getElementById('config-screen').style.display='none';
        document.getElementById('app').style.display='block';
        document.getElementById('st-db-url').textContent=cfg.databaseURL;
        initApp();
        setStatus('','');
      }
    });
    setTimeout(()=>{
      if(!db)setStatus('❌ Could not connect — check your config','var(--red)');
    },6000);
  }catch(err){setStatus('❌ '+err.message,'var(--red)');}
}

function setStatus(msg,color){
  const el=document.getElementById('cfg-status');
  el.textContent=msg;el.style.color=color;
}

function setSyncStatus(connected){
  const dot=document.getElementById('sync-dot');
  const lbl=document.getElementById('sync-label');
  const sdot=document.getElementById('st-sync-dot');
  if(dot){dot.className='status-dot '+(connected?'green':'red');}
  if(lbl){lbl.textContent=connected?'Live':'Reconnecting…';}
  if(sdot){sdot.className='status-dot '+(connected?'green':'red');}
}

// ── Firebase DB helpers ─────────────────────────────────────
function ref(path){return db.ref(path);}

function dbGet(path,cb){
  ref(path).once('value',snap=>cb(snap.val()));
}

function dbSet(path,val){
  return ref(path).set(val);
}

function dbPush(path,val){
  return ref(path).push(val);
}

function dbRemove(path){
  return ref(path).remove();
}

function dbListen(key,path,cb){
  if(LISTENERS[key])ref(LISTENERS[key]).off();
  LISTENERS[key]=path;
  ref(path).on('value',snap=>{cb(snap.val()||getDefault(key));});
}

function getDefault(key){
  const defs={emails:[],transactions:[],staff:[],todos:[],chat_msgs:[],inventory:[],incidents:[],schedule:{},contacts:[],reports:[],config:{name:'Velvet Anchor',pass:'storyteller',wallpaper:'default'}};
  return defs[key]!==undefined?defs[key]:null;
}

// Convert Firebase object to array (Firebase stores arrays as objects with keys)
function toArr(val){
  if(!val)return[];
  if(Array.isArray(val))return val;
  return Object.entries(val).map(([k,v])=>({...v,_key:k})).sort((a,b)=>(a._ts||0)-(b._ts||0));
}

// Newest-first array from Firebase
function toArrDesc(val){return toArr(val).reverse();}

// ════════════════════════════════════════════════════════════
//  APP INIT — start all listeners
// ════════════════════════════════════════════════════════════
function initApp(){
  loadConfig();
  updateClock();setInterval(updateClock,1000);
  updateMailBadge();
  // Listen for new chat messages to flash badge
  dbListen('chat_msgs_notify','chat_msgs',()=>updateChatBadge());
}

function loadConfig(){
  dbGet('config',cfg=>{
    if(!cfg)return;
    const name=cfg.name||'Velvet Anchor';
    document.getElementById('mb-logo').textContent='⬡ '+name;
    document.title=name+' — Manager Console';
    const st=document.getElementById('st-biz-name');if(st)st.value=name;
    if(cfg.wallpaper&&cfg.wallpaper!=='default'){
      const wp=WALLPAPERS[cfg.wallpaper]||cfg.customWP||null;
      if(wp)document.body.style.background=wp;
    }
  });
}

// ════════════════════════════════════════════════════════════
//  WINDOW MANAGER
// ════════════════════════════════════════════════════════════
let zTop=10;
const wins={};
const defaultPositions={
  mail:{x:40,y:20,w:560,h:420},bank:{x:620,y:20,w:440,h:460},
  staff:{x:40,y:200,w:400,h:400},todo:{x:460,y:200,w:340,h:360},
  chat:{x:820,y:160,w:480,h:420},inventory:{x:40,y:350,w:420,h:360},
  incident:{x:480,y:330,w:420,h:380},schedule:{x:80,y:80,w:660,h:360},
  rolodex:{x:200,y:120,w:440,h:400},report:{x:300,y:60,w:520,h:400},
};

function openApp(id){
  if(wins[id]){bringToFront(wins[id]);return;}
  const p=defaultPositions[id]||{x:80,y:60,w:480,h:380};
  const el=document.createElement('div');
  el.className='win';el.id='win-'+id;
  el.style.cssText=`left:${p.x}px;top:${p.y}px;width:${p.w}px;height:${p.h}px;`;
  const app=APPS[id];
  el.innerHTML=`
    <div class="win-titlebar" onmousedown="startDrag(event,'${id}')">
      <div class="win-dots">
        <div class="win-dot close" onclick="closeApp('${id}')"></div>
        <div class="win-dot min"></div>
        <div class="win-dot max" onclick="maximizeWin('${id}')"></div>
      </div>
      <span style="font-size:13px">${app.icon}</span>
      <span class="win-title">${app.title}</span>
    </div>
    <div class="win-body" id="body-${id}">${app.build()}</div>
    <div class="win-resize" onmousedown="startResize(event,'${id}')"></div>
  `;
  document.getElementById('desktop').appendChild(el);
  wins[id]=el;bringToFront(el);
  document.getElementById('dock-'+id)?.classList.add('open');
  app.init&&app.init();
}

function closeApp(id){
  // Detach Firebase listeners for this app
  const key='app_'+id;
  if(LISTENERS[key]){ref(LISTENERS[key]).off();delete LISTENERS[key];}
  wins[id]?.remove();delete wins[id];
  document.getElementById('dock-'+id)?.classList.remove('open');
}

function bringToFront(el){
  el.style.zIndex=++zTop;
  document.querySelectorAll('.win').forEach(w=>w.classList.remove('active'));
  el.classList.add('active');
}

function maximizeWin(id){
  const el=wins[id];if(!el)return;
  if(el.dataset.maxed){el.style.cssText=el.dataset.prev;delete el.dataset.maxed;}
  else{el.dataset.prev=el.style.cssText;el.dataset.maxed=1;el.style.cssText='left:0;top:0;width:100%;height:100%;border-radius:0;';}
}

let dragWin=null,dragOX=0,dragOY=0;
function startDrag(e,id){
  if(e.target.classList.contains('win-dot'))return;
  dragWin=wins[id];dragOX=e.clientX-dragWin.offsetLeft;dragOY=e.clientY-dragWin.offsetTop;
  bringToFront(dragWin);e.preventDefault();
}
document.addEventListener('mousemove',e=>{
  if(dragWin){dragWin.style.left=(e.clientX-dragOX)+'px';dragWin.style.top=Math.max(0,e.clientY-dragOY)+'px';}
  if(resizeWin){resizeWin.style.width=Math.max(280,e.clientX-resizeWin.offsetLeft)+'px';resizeWin.style.height=Math.max(200,e.clientY-resizeWin.offsetTop)+'px';}
});
document.addEventListener('mouseup',()=>{dragWin=null;resizeWin=null;});
let resizeWin=null;
function startResize(e,id){resizeWin=wins[id];e.preventDefault();e.stopPropagation();}

