function g(id){const el=document.getElementById(id);return el?el.value:'';}
function gv(id){return g(id);}
function nowTime(){return new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});}
function showModal(html){document.getElementById('modal-content').innerHTML=html;document.getElementById('modal-overlay').classList.add('show');}
function closeModal(){document.getElementById('modal-overlay').classList.remove('show');}
function closeModalOutside(e){if(e.target===document.getElementById('modal-overlay'))closeModal();}
let toastTimer;
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),2400);}
function updateClock(){const el=document.getElementById('mb-time');if(el)el.textContent=new Date().toLocaleString([],{weekday:'short',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});}

// Auto-reconnect from saved config
window.addEventListener('load',()=>{
  const saved=localStorage.getItem('va_firebase_cfg');
  if(saved){
    try{
      const cfg=JSON.parse(saved);
      document.getElementById('cfg-paste').value=JSON.stringify(cfg,null,2);
    }catch(e){}
  }
});
