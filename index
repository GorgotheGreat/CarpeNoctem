function renderChat(){renderChatContacts();renderChatMessages();}
function renderChatContacts(){
  const contacts=[...new Set(_msgs.map(m=>m.contact).filter(Boolean))];
  const el=document.getElementById('chat-contacts');if(!el)return;
  el.innerHTML='';
  if(!contacts.length){el.innerHTML='<div style="padding:12px;font-size:11px;color:var(--text3)">No messages yet</div>';return;}
  contacts.forEach(c=>{
    const last=_msgs.filter(m=>m.contact===c).slice(-1)[0];
    const d=document.createElement('div');
    d.className='chat-contact'+(activeChatContact===c?' active':'');
    d.innerHTML=`<div style="font-size:12px;font-weight:500">${c}</div><div style="font-size:10px;color:var(--text3);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${last?last.text:''}</div>`;
    d.onclick=()=>{activeChatContact=c;renderChat();};
    el.appendChild(d);
  });
}
function renderChatMessages(){
  const el=document.getElementById('chat-messages');if(!el)return;
  const nameEl=document.getElementById('chat-active-name');
  if(!activeChatContact){el.innerHTML='<div style="padding:24px;text-align:center;color:var(--text3);font-size:13px">Select a contact</div>';return;}
  if(nameEl)nameEl.textContent=activeChatContact;
  const msgs=_msgs.filter(m=>m.contact===activeChatContact);
  el.innerHTML='';
  msgs.forEach(m=>{
    const d=document.createElement('div');d.style.cssText='display:flex;'+(m.sender==='player'?'justify-content:flex-end':'');
    if(m.type==='system'){
      d.innerHTML=`<div class="chat-bubble system">${m.text}</div>`;
    } else {
      d.innerHTML=`<div><div class="chat-bubble ${m.sender==='player'?'player':'npc'}">${m.text}</div><div style="font-size:9px;color:var(--text3);margin-top:2px;text-align:${m.sender==='player'?'right':'left'}">${m.time||''}</div></div>`;
    }
    el.appendChild(d);
  });
  el.scrollTop=el.scrollHeight;
}
function playerSendChat(){
  if(!activeChatContact)return;
  const inp=document.getElementById('chat-input');
  const val=inp.value.trim();if(!val)return;
  dbPush('chat_msgs',{contact:activeChatContact,sender:'player',text:val,time:nowTime(),type:'player',_ts:Date.now()});
  inp.value='';
}
function updateChatBadge(){
  // If chat window isn't open, flash badge
  if(!wins['chat']){
