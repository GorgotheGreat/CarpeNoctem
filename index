const WALLPAPERS={
  default:'linear-gradient(135deg,#1a0533 0%,#0d1a2e 40%,#0a0f1a 100%)',
  midnight:'linear-gradient(160deg,#000000 0%,#0a0a1a 50%,#050510 100%)',
  forest:'linear-gradient(135deg,#0a1f0a 0%,#0f2a1a 50%,#081508 100%)',
  ember:'linear-gradient(135deg,#1a0800 0%,#2a1000 40%,#100500 100%)',
  ocean:'linear-gradient(135deg,#001a2e 0%,#002e4a 50%,#000e1a 100%)',
  rose:'linear-gradient(135deg,#1a0010 0%,#2e0020 50%,#0f0008 100%)',
};
function openWallpaperPicker(){
  const opts=Object.keys(WALLPAPERS).map(k=>`<div class="wallpaper-option" style="background:${WALLPAPERS[k]}" onclick="setWallpaper('${k}',this)" title="${k}"></div>`).join('');
  showModal(`
    <h2>Appearance</h2>
    <label style="margin-bottom:10px">Wallpaper</label>
    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px">${opts}</div>
    <div class="form-row"><label>Custom CSS gradient</label><input class="input" id="wp-custom" placeholder="linear-gradient(…)"></div>
    <div class="modal-actions"><button class="btn" onclick="closeModal()">Done</button><button class="btn btn-primary" onclick="applyCustomWP()">Apply Custom</button></div>
  `);
}
function setWallpaper(key,el){
  document.querySelectorAll('.wallpaper-option').forEach(o=>o.classList.remove('active'));
  el.classList.add('active');
  document.body.style.background=WALLPAPERS[key];
  dbGet('config',cfg=>{cfg=cfg||{};cfg.wallpaper=key;dbSet('config',cfg);});
}
function applyCustomWP(){
  const val=document.getElementById('wp-custom').value.trim();if(!val)return;
  document.body.style.background=val;
  dbGet('config',cfg=>{cfg=cfg||{};cfg.wallpaper='custom';cfg.customWP=val;dbSet('config',cfg);});
  closeModal();
}

