// ════════════════════════════════════════════════════════════
//  REVENUE GENERATOR
// ════════════════════════════════════════════════════════════
const RANDOM_EVENTS={
  good:[
    {name:'Local band drew a big crowd',mult:1.35,note:'Walk-in traffic was way up.'},
    {name:'Bachelorette party blitz',mult:1.28,note:'A dozen groups rolled in back-to-back.'},
    {name:'Sports watch party',mult:1.45,note:'Championship game packed the bar.'},
    {name:'Viral social media post',mult:1.22,note:"Someone's post blew up — bar was slammed."},
    {name:'Corporate private buyout',mult:1.60,extra:800,note:'A company booked the bar for 3 hours.'},
    {name:'VIP high-roller visit',mult:1.15,extra:1200,note:'Big spender rolled in with an entourage.'},
    {name:'Food critic in the house',mult:1.08,note:'Quiet night but a critic was there. Reputation incoming.'},
  ],
  bad:[
    {name:'Health inspector surprise visit',mult:0.70,expense:600,note:'Emergency cleaning and a citation.'},
    {name:'Bar fight — early shutdown',mult:0.50,note:'Police called; closed 2 hours early.'},
    {name:'Keg delivery wrong — short order',mult:0.82,note:'Ran dry on two taps mid-shift.'},
    {name:'AC unit failed mid-shift',mult:0.75,expense:900,note:'Customers left early in the heat.'},
    {name:'Credit card terminal down 2 hrs',mult:0.88,note:'Cash-only for part of the night.'},
    {name:'Social media complaint went viral',mult:0.72,note:'Negative post spread. Walk-ins killed.'},
    {name:'Key bartender no-showed',mult:0.80,note:'Scrambled to cover — slow service all night.'},
    {name:'Plumbing emergency',mult:0.60,expense:1400,note:'Pipes backed up. Bar partially unusable.'},
  ]
};

function generateRevenue(previewOnly){
  const nights=parseInt(gv('gen-nights'))||1;
  const covers=parseInt(gv('gen-covers'))||100;
  const spend=parseInt(gv('gen-spend'))||40;
  const type=gv('gen-type');
  const payroll=parseInt(gv('gen-payroll'))||800;
  const supply=parseInt(gv('gen-supply'))||400;
  const eventMode=gv('gen-event');
  const typeMults={normal:[0.85,1.15],slow:[0.55,0.80],busy:[1.15,1.40],event:[1.30,1.65]};
  const [tMin,tMax]=typeMults[type]||[0.9,1.1];

  let totalRev=0,totalExp=0,eventsFired=[],breakdown=[];
  for(let n=0;n<nights;n++){
    const v=tMin+(Math.random()*(tMax-tMin));
    const nightCovers=Math.round(covers*v+(Math.random()*10-5));
    let nightRev=Math.round(nightCovers*spend);
    let nightExp=payroll+supply;
    let evt=null;
    const doEvent=(eventMode==='random'&&Math.random()<0.25)||eventMode==='good'||eventMode==='bad';
    if(doEvent){
      const good=eventMode==='good'||(eventMode==='random'&&Math.random()>0.45);
      const pool=good?RANDOM_EVENTS.good:RANDOM_EVENTS.bad;
      evt=pool[Math.floor(Math.random()*pool.length)];
      nightRev=Math.round(nightRev*(evt.mult||1))+(evt.extra||0);
      nightExp+=evt.expense||0;
      eventsFired.push(evt);
    }
    totalRev+=nightRev;totalExp+=nightExp;
    breakdown.push({n:n+1,rev:nightRev,exp:nightExp,covers:nightCovers,evt});
  }
  const net=totalRev-totalExp;
  const bkHtml=nights<=7?breakdown.map(b=>`
    <div style="display:flex;justify-content:space-between;font-size:11px;padding:4px 0;border-bottom:0.5px solid var(--border2)">
      <span style="color:var(--text3)">Night ${b.n}${b.evt?` — <em style="color:var(--amber)">${b.evt.name}</em>`:''}</span>
      <span>${b.covers} covers · <span style="color:var(--green)">+${fmt(b.rev)}</span> / <span style="color:var(--red)">-${fmt(b.exp)}</span></span>
    </div>`).join(''):'';
  const evtHtml=eventsFired.length?`<div style="margin-top:10px"><div style="font-size:11px;font-weight:600;color:var(--amber);margin-bottom:4px">Events</div>${eventsFired.map(e=>`<div style="font-size:11px;color:var(--text2);margin-bottom:3px">⚡ <strong>${e.name}</strong> — ${e.note}</div>`).join('')}</div>`:'';

  const res=document.getElementById('gen-result');
  res.className='gen-result show';
  res.innerHTML=`
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:10px">
      <div style="text-align:center"><div style="font-size:10px;color:var(--text3)">Total Revenue</div><div style="font-size:18px;font-weight:500;color:var(--green)">${fmt(totalRev)}</div></div>
      <div style="text-align:center"><div style="font-size:10px;color:var(--text3)">Total Expenses</div><div style="font-size:18px;font-weight:500;color:var(--red)">${fmt(totalExp)}</div></div>
      <div style="text-align:center"><div style="font-size:10px;color:var(--text3)">Net Profit</div><div style="font-size:18px;font-weight:500;color:${net>=0?'var(--green)':'var(--red)'}">${net>=0?'+':''}${fmt(net)}</div></div>
    </div>${bkHtml}${evtHtml}
    ${!previewOnly?'<div style="margin-top:10px;font-size:11px;color:var(--green)">✓ Posted to Firebase — player will see this instantly</div>':'<div style="margin-top:10px;font-size:11px;color:var(--amber)">Preview only — not posted</div>'}
  `;

  if(!previewOnly){
    const now=new Date().toLocaleDateString();
    dbPush('transactions',{label:nights===1?'Night revenue':'Revenue ('+nights+' nights)',type:'income',amount:totalRev,date:now,_ts:Date.now()});
    dbPush('transactions',{label:'Operating expenses'+(nights>1?' ('+nights+' nights)':''),type:'expense',amount:totalExp,date:now,_ts:Date.now()+1});
    eventsFired.filter(e=>e.expense).forEach(e=>{
      dbPush('incidents',{title:e.name,date:'Auto-generated',severity:'med',body:e.note,filed:'auto',_ts:Date.now()});
    });
    eventsFired.forEach(e=>{
      const isGood=RANDOM_EVENTS.good.includes(e);
      dbPush('chat_msgs',{contact:'System',sender:'system',text:(isGood?'📈 ':'⚠️ ')+e.name+' — '+e.note,time:nowTime(),type:'system',_ts:Date.now()});
    });
    showToast('Posted to Firebase — player sees it now');
  }
}

