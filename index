//  BANK
// ════════════════════════════════════════════════════════════
function renderBank(){
  const balance=_txs.reduce((s,t)=>t.type==='income'?s+t.amount:s-t.amount,0);
  const income=_txs.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0);
  const exp=_txs.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const bd=document.getElementById('balance-display');
  if(bd){bd.textContent=fmt(balance);bd.style.color=balance>=0?'var(--text)':'var(--red)';}
  const bi=document.getElementById('balance-income');if(bi)bi.textContent=fmt(income);
  const be=document.getElementById('balance-exp');if(be)be.textContent=fmt(exp);
  const list=document.getElementById('tx-list');if(!list)return;
  list.innerHTML=_txs.length?'':'<div style="padding:24px;text-align:center;color:var(--text3);font-size:13px">No transactions yet</div>';
  _txs.forEach(t=>{
    const d=document.createElement('div');d.className='tx-item';
    d.innerHTML=`
      <div style="flex:1;min-width:0">
        <div style="font-size:13px">${t.type==='income'?'🟢':'🔴'} ${t.label||''}</div>
        <div style="font-size:11px;color:var(--text3)">${t.date||''}</div>
      </div>
      <div class="tx-amount ${t.type==='income'?'pos':'neg'}">${t.type==='income'?'+':'−'}${fmt(t.amount||0)}</div>
    `;
    list.appendChild(d);
  });
}
function fmt(n){return'$'+Math.abs(n).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});}

